{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/schemas/v2/tauri.conf.json",
  "productName": "Peacock",
  "version": "0.1.0",
  "identifier": "com.peacock.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Peacock",
        "width": 900,
        "height": 640,
        "minWidth": 700,
        "minHeight": 500,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
